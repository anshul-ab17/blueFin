# bluefin-api
# Bind loopback only — nginx (infra/nginx/bluefin-api.conf) terminates TLS and proxies to this.
# Never expose :8787 publicly (it is plaintext HTTP).
BIND_ADDR=127.0.0.1:8787
DATABASE_URL=sqlite://bluefin.db?mode=rwc
# CORS: comma-separated allowed origins (prod). Leave empty for permissive dev CORS.
# e.g. ALLOWED_ORIGINS=https://bluefin.vercel.app, https://www.bluefin.app
ALLOWED_ORIGINS=

# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
BLUEFIN_PROGRAM_ID=BbeCFPpsNTi5sqBNWjeXPtAitzqnDhYEMVxkLQodNH3B
# currency mint = TxLINE TxL devnet mint (Token-2022)
TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
# backend oracle/quote authority keypair (JSON array), e.g. ~/.config/solana/id.json contents
ORACLE_KEYPAIR_PATH=

# TxLINE devnet
TXLINE_BASE_URL=https://txline-dev.txodds.com
TXODDS_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_JWT=
TXLINE_API_TOKEN=
